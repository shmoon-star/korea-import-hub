# Supabase (새 프로젝트 생성 후 Project Settings > API에서 복사)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 관세청 UNI-PASS OpenAPI
# https://unipass.customs.go.kr 에서 발급 (mwms-lite와 동일 키 재사용 가능)
UNIPASS_API_KEY=

# 앱 기본 URL (이메일 링크 등에서 사용 — 추후)
APP_BASE_URL=http://localhost:3000
